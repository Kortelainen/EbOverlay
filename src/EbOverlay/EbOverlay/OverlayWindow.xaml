<Window x:Class="EbOverlay.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="EbOverlay"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        IsHitTestVisible="False">

    <!-- Root canvas — full screen, all zones positioned in code-behind via PositionAllElements() -->
    <Canvas x:Name="RootCanvas">

        <!-- [TOP-LEFT] App name — filled by AppNameZone in M2 -->
        <TextBlock x:Name="AppNameText"
                   Foreground="#66FF99"
                   FontFamily="Courier New"
                   FontSize="13"
                   Opacity="0"
                   Text="—" />

        <!-- [TOP-RIGHT] Clock — filled by ClockZone in M2 -->
        <TextBlock x:Name="ClockText"
                   Foreground="#66FF99"
                   FontFamily="Courier New"
                   FontSize="13"
                   Opacity="0.6"
                   Text="00:00" />

        <!-- [BOT-RIGHT] System metrics — filled by MetricsZone in M3 -->
        <StackPanel x:Name="MetricsPanel"
                    Orientation="Vertical"
                    HorizontalAlignment="Right"
                    Opacity="0.5">
            <TextBlock x:Name="CpuText"
                       Foreground="#66FF99"
                       FontFamily="Courier New"
                       FontSize="11"
                       Text="CPU  --%"
                       HorizontalAlignment="Right" />
            <TextBlock x:Name="RamText"
                       Foreground="#66FF99"
                       FontFamily="Courier New"
                       FontSize="11"
                       Text="RAM  --/-- GB"
                       HorizontalAlignment="Right" />
        </StackPanel>

        <!-- [BOT-LEFT] Network metrics — filled by NetworkMetrics in M3 -->
        <StackPanel x:Name="NetPanel"
                    Orientation="Vertical"
                    Opacity="0.5">
            <TextBlock x:Name="NetUpText"
                       Foreground="#66FF99"
                       FontFamily="Courier New"
                       FontSize="11"
                       Text="↑  --" />
            <TextBlock x:Name="NetDownText"
                       Foreground="#66FF99"
                       FontFamily="Courier New"
                       FontSize="11"
                       Text="↓  --" />
        </StackPanel>

        <!-- [MID-RIGHT] Sprite zone — filled by SpriteZone in M4 -->
        <Image x:Name="SpriteImage"
               Width="96"
               Height="96"
               RenderOptions.BitmapScalingMode="NearestNeighbor"
               Opacity="0.85" />

    </Canvas>
</Window>
